# ═══════════════════════════════════════════════════════════════
# NetBrain AI — .env file
# Location: network-intelligence-platform/.env  (repo root)
# ═══════════════════════════════════════════════════════════════

# ── AI (required) ─────────────────────────────────────────────
OPENROUTER_API_KEY= 

# ── GNS3 Router SSH credentials ───────────────────────────────
# Must match what is configured on your GNS3 router.
GNS3_SSH_USER=admin
GNS3_SSH_PASS=admin
GNS3_SSH_SECRET=admin
GNS3_DEVICE_TYPE=cisco_ios

# ── Tunnel (optional) ─────────────────────────────────────────
GNS3_TUNNEL_URL=
PINGGY_FALLBACK_URL=

# ── Streamlit ─────────────────────────────────────────────────
STREAMLIT_PORT=8501
